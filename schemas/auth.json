{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "roles": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "permissions": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": [
                    "name",
                    "permissions"
                ],
                "additionalProperties": false
            }
        },
        "rules": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "roles",
        "rules"
    ],
    "additionalProperties": false
}