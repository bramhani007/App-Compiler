{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "pages": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "entities": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "fields": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": [
                    "name",
                    "fields"
                ],
                "additionalProperties": false
            }
        },
        "apis": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string"
                    },
                    "method": {
                        "type": "string",
                        "enum": [
                            "GET",
                            "POST",
                            "PUT",
                            "DELETE"
                        ]
                    },
                    "description": {
                        "type": "string"
                    }
                },
                "required": [
                    "path",
                    "method",
                    "description"
                ],
                "additionalProperties": false
            }
        },
        "roles": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "pages",
        "entities",
        "apis",
        "roles"
    ],
    "additionalProperties": false
}