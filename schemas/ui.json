{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "pages": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "layout": {
                        "type": "string"
                    },
                    "components": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": {
                                    "type": "string"
                                },
                                "props": {
                                    "type": "object"
                                },
                                "dataBinding": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "type",
                                "props"
                            ],
                            "additionalProperties": false
                        }
                    }
                },
                "required": [
                    "name",
                    "layout",
                    "components"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "pages"
    ],
    "additionalProperties": false
}